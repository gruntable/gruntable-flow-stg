{
  "node_type": "ai_extraction",
  "version": "1.0.0",
  "label": "AI Extraction PDF, Spreadsheet, Image",
  "icon": "🗂️",
  "category": "Extract and Process",
  "desc": "Upload a file and let AI extract structured data from it. File upload is required.",
  "behavior": "ai_form",
  "requires_file": true,
  "requires_prompt": false,
  "requires_table_input": false,
  "max_input_tables": 1,
  "table_output_mode": "required",
  "is_export": false,
  "qc_mode": "pause_review",
  "pauseForReview": true,
  "defaults": {
    "table_name": "AI Extraction Output",
    "file_type": "pdf",
    "extraction_mode": "per_page"
  },
  "ui": {
    "prompt_label": "Extraction Prompt",
    "prompt_placeholder": "e.g. Extract all transactions from this bank statement",
    "table_name_label": "Output Table Name",
    "table_name_hint": "Name this table to reference it in downstream nodes.",
    "processing_label": "Extracting data...",
    "file_type_options": [
      {
        "value": "pdf",
        "label": "PDF"
      },
      {
        "value": "xlsx",
        "label": "XLSX"
      },
      {
        "value": "csv",
        "label": "CSV"
      },
      {
        "value": "image",
        "label": "Images (PNG, JPG, JPEG)"
      }
    ],
    "extraction_mode_options": [
      {
        "value": "per_page",
        "label": "Per Page"
      },
      {
        "value": "per_file",
        "label": "Per File"
      }
    ]
  },
  "n8n_workflows": [
    {
      "id": "ai-extraction-pdf",
      "label": "PDF Extraction",
      "filename": "n8n/pages/workflows/nodes/ai-extraction/ai-extraction-pdf.form.json",
      "trigger_type": "form",
      "trigger_path": "/form/ai-extraction-pdf",
      "file_type_filter": "pdf"
    },
    {
      "id": "ai-extraction-image",
      "label": "Image Extraction",
      "filename": "n8n/pages/workflows/nodes/ai-extraction/ai-extraction-image.form.json",
      "trigger_type": "form",
      "trigger_path": "/form/ai-extraction-image",
      "file_type_filter": "image"
    },
    {
      "id": "ai-extraction-xlsx",
      "label": "XLSX Extraction",
      "filename": "n8n/pages/workflows/nodes/ai-extraction/ai-extraction-xlsx.form.json",
      "trigger_type": "form",
      "trigger_path": "/form/ai-extraction-xlsx",
      "file_type_filter": "xlsx"
    },
    {
      "id": "ai-extraction-csv",
      "label": "CSV Extraction",
      "filename": "n8n/pages/workflows/nodes/ai-extraction/ai-extraction-csv.form.json",
      "trigger_type": "form",
      "trigger_path": "/form/ai-extraction-csv",
      "file_type_filter": "csv"
    }
  ]
}
