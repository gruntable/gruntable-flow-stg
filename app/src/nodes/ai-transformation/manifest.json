{
  "node_type": "ai_transformation",
  "version": "1.0.0",
  "label": "AI Transformation",
  "icon": "✨",
  "category": "Extract and Process",
  "desc": "Apply an AI transformation to an upstream table using a text prompt. No file upload needed.",
  "behavior": "ai_go",
  "requires_file": false,
  "requires_prompt": true,
  "requires_table_input": true,
  "max_input_tables": 5,
  "table_output_mode": "required",
  "is_export": false,
  "qc_mode": "pause_review",
  "pauseForReview": true,
  "defaults": {
    "table_name": "AI Transformation Output"
  },
  "ui": {
    "prompt_label": "Transformation Prompt",
    "prompt_placeholder": "e.g. Normalize all dates to YYYY-MM-DD, remove duplicate rows",
    "table_name_label": "Output Table Name",
    "table_name_hint": "Name this table to reference it in downstream nodes.",
    "processing_label": "Applying transformation..."
  },
  "n8n_workflows": [
    {
      "id": "ai-transformation",
      "label": "AI Transformation",
      "filename": "n8n/pages/workflows/nodes/ai-transformation/ai-transformation.webhook.json",
      "trigger_type": "webhook",
      "trigger_path": "/webhook/ai-transformation"
    }
  ]
}
